config WDT_NXP_SWT
	bool "NXP Software Watchdog Timer (SWT) driver"
	default y
	depends on DT_HAS_NXP_SWT_ENABLED
	select CLOCK_CONTROL
	select NOCACHE_MEMORY if ARCH_HAS_NOCACHE_MEMORY_SUPPORT
	help
	  Enable the Software Watchdog Timer (SWT) driver.
